# Keil MDK (若專案使用到)
# -----------------------------
*.uvoptx
*.uvguix.*
*.axf
*.o
*.crf
*.d
*.map
*.lst
*.tra
*.plg
keil/Objects/
keil/Listing/

# -----------------------------
# CMake/Build 輸出
# -----------------------------
build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json
CMakeUserPresets.json

# -----------------------------
# VSCode 設定檔
# 保留 settings.json / c_cpp_properties.json
# 忽略 launch.json、tasks.json 等個人化設定
# -----------------------------
code/.vscode/launch.json

# -----------------------------
# Clangd 設定與快取
# -----------------------------
.clangd
build/*/.cache/clangd/

